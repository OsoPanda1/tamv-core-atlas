{
  "$schema": "https://tamv.org/schemas/tamv-atlas-kernel.schema.json",
  "kernel": {
    "name": "TAMV Core Atlas Kernel",
    "codename": "ANUBIS",
    "version": "1.0.0-omnikernel-isabella-hardened",
    "architecture": "heptafederated-cognitive-runtime",
    "mode": "production-staging",
    "classification": "civilizational-operating-atlas",
    "description": "Federated semantic atlas and sovereign intelligence runtime for ingestion, cognition, prediction, governance and publication, fronted by OmniKernelGatewayX6 and governed by IsabellaEngine v3.",
    "status": {
      "ui_readiness": 0.71,
      "atlas_pipeline_readiness": 0.85,
      "semantic_runtime_readiness": 0.72,
      "prediction_engine_readiness": 0.56,
      "production_deploy_readiness": 0.69,
      "security_maturity": 0.91,
      "federation_coherence": 0.81,
      "overall_realistic_readiness": 0.74
    },
    "mission": "Transform fragmented repositories, entities and signals into a sovereign semantic atlas with auditable governance, strong zero-trust security and heptafederated cognition.",
    "vision": "Become a hardened sovereign intelligence substrate capable of indexing, classifying, correlating and evolving distributed ecosystems through secure semantic cognition, with embedded epistemic counter-audit and ecosystem verification.",
    "objectives": [
      "Build sovereign semantic infrastructure with identity-first zero-trust",
      "Enable federated repository cognition and heptafederated validation",
      "Create cryptographically auditable knowledge graphs and decision trails",
      "Enable semantic observability and ecosystem auditability",
      "Provide deployable intelligence layers with strict policy enforcement",
      "Reduce architectural and epistemic entropy",
      "Enable scalable civilizational coordination with strong safety rails"
    ]
  },

  "runtime": {
    "gateway": {
      "engine": "OmniKernelGatewayX6",
      "modes": ["STRICT", "AUDIT_ONLY"],
      "features": {
        "rate_limiting": {
          "enabled": true,
          "window_ms": 60000,
          "max_requests_per_window": 120,
          "per_user_daily_quota": 1000
        },
        "replay_protection": {
          "enabled": true,
          "window_ms": 60000,
          "cache_backend": "redis"
        },
        "payload_constraints": {
          "max_payload_bytes": 131072,
          "forbidden_content_types": ["binary/executable", "archive/encrypted"]
        },
        "governance_layer": {
          "engine": "DekateorlEngine",
          "strict_mode": true,
          "hard_stops": [
            "child exploitation",
            "terrorism",
            "human trafficking",
            "mass violence"
          ],
          "pattern_sets": [
            "abuse-manipulation",
            "misinformation",
            "malware-phishing",
            "harassment-extortion"
          ]
        },
        "threat_intel": {
          "engine": "AnubisSentinel",
          "max_anomaly_score": 0.75,
          "block_on_critical": true,
          "signals": [
            "payload_size",
            "injection_patterns",
            "sensitive_pattern_exposure"
          ]
        },
        "ledger": {
          "engine": "BookPIChain",
          "immutable": true,
          "integrity": {
            "hash": "sha256",
            "hmac": "sha256",
            "sign_events": true,
            "verify_on_boot": true
          },
          "projection_targets": [
            "atlas_store_economy",
            "atlas_audit_log"
          ]
        }
      }
    },
    "governance": {
      "engine": "IsabellaEngineV3",
      "profiles": [
        "general",
        "contra-auditoria",
        "simulacion",
        "secretaria",
        "gobernanza",
        "auditoria-ecosistema"
      ],
      "heptafederation": {
        "enabled": true,
        "federations": [
          "Sociologica",
          "Identidad",
          "Gobernanza",
          "Territorial",
          "Educativa",
          "Tecnologica",
          "Economica"
        ],
        "min_score": 0.5,
        "risk_bands": ["alto", "medio", "bajo"]
      },
      "entropy": {
        "enabled": true,
        "shannon_threshold": 1.5,
        "apply_to": [
          "argument_streams",
          "ecosystem_claims",
          "prediction_outputs"
        ]
      },
      "ecosystem_audit": {
        "enabled": true,
        "default_dossier_id": "tamv-rd-nodo-001-genesis",
        "modes": {
          "pre_deploy": true,
          "continuous": true
        },
        "decision_policy": {
          "execute_if_confidence_gte": 0.6,
          "require_human_review_between": [0.4, 0.6],
          "block_if_confidence_lt": 0.4
        }
      }
    }
  },

  "federations": {
    "atlas": {
      "role": "knowledge-mapping",
      "priority": "critical",
      "modules": [
        "ontology-engine",
        "semantic-graph",
        "entity-resolution",
        "federated-indexing"
      ]
    },
    "nexus": {
      "role": "relationship-topology",
      "priority": "high",
      "modules": [
        "graph-runtime",
        "edge-weighting",
        "similarity-engine",
        "causal-linking"
      ]
    },
    "korima": {
      "role": "economic-intelligence",
      "priority": "medium",
      "modules": [
        "token-analysis",
        "economic-scoring",
        "market-signals"
      ]
    },
    "eoct": {
      "role": "operations-command",
      "priority": "critical",
      "modules": [
        "telemetry",
        "observability",
        "runtime-health",
        "audit-stream"
      ]
    },
    "mdx5": {
      "role": "content-assembly",
      "priority": "medium",
      "modules": [
        "markdown-pipeline",
        "document-synthesis",
        "semantic-rendering"
      ]
    },
    "csp": {
      "role": "canon-security-protocol",
      "priority": "critical",
      "modules": [
        "zero-trust",
        "policy-validation",
        "secret-redaction",
        "supply-chain-defense"
      ]
    },
    "heptacore": {
      "role": "kernel-orchestration",
      "priority": "critical",
      "modules": [
        "scheduler",
        "workflow-engine",
        "runtime-router",
        "event-bus"
      ]
    }
  },

  "pipeline": {
    "execution_model": "distributed-event-driven",
    "strategy": "incremental-semantic-orchestration",
    "preconditions": {
      "identity_attestation_required": true,
      "isabella_audit_required": true,
      "gateway_clearance_required": true
    },
    "steps": [
      {
        "id": "discover",
        "enabled": true,
        "description": "Discover repositories, entities and sources",
        "engine": "github-discovery-engine",
        "concurrency": 6,
        "retry_policy": {
          "attempts": 5,
          "backoff": "exponential-jitter"
        }
      },
      {
        "id": "fetch",
        "enabled": true,
        "description": "Secure evidence acquisition",
        "engine": "safe-fetch-runtime",
        "restrictions": {
          "allow_symlinks": false,
          "allow_exec": false,
          "allow_binary": false,
          "max_file_size_mb": 4
        }
      },
      {
        "id": "sanitize",
        "enabled": true,
        "description": "Redact secrets and normalize evidence",
        "engine": "csp-redaction-engine"
      },
      {
        "id": "extract",
        "enabled": true,
        "description": "Extract metadata and semantic signals",
        "engine": "semantic-extractor"
      },
      {
        "id": "normalize",
        "enabled": true,
        "description": "Canonical normalization",
        "engine": "canonical-normalizer"
      },
      {
        "id": "classify",
        "enabled": true,
        "description": "Deterministic rule classification",
        "engine": "classification-engine"
      },
      {
        "id": "categorize",
        "enabled": true,
        "description": "Multi-label semantic categorization",
        "engine": "semantic-taxonomy-engine"
      },
      {
        "id": "embed",
        "enabled": true,
        "description": "Generate semantic embeddings",
        "engine": "embedding-runtime"
      },
      {
        "id": "relate",
        "enabled": true,
        "description": "Construct weighted graph relations",
        "engine": "federated-graph-builder"
      },
      {
        "id": "cluster",
        "enabled": true,
        "description": "Semantic clustering and topology grouping",
        "engine": "semantic-clustering-engine"
      },
      {
        "id": "predict",
        "enabled": true,
        "description": "Predict maturity and evolution",
        "engine": "predictive-intelligence-runtime",
        "hardening": {
          "entropy_check": true,
          "drift_detection": true
        }
      },
      {
        "id": "score",
        "enabled": true,
        "description": "Calculate operational scores",
        "engine": "scoring-engine"
      },
      {
        "id": "publish",
        "enabled": true,
        "description": "Publish atlas artifacts",
        "engine": "atlas-publisher"
      },
      {
        "id": "observe",
        "enabled": true,
        "description": "Telemetry and runtime metrics",
        "engine": "observability-runtime"
      }
    ]
  },

  "semantic_search": {
    "enabled": true,
    "mode": "hybrid",
    "strategies": {
      "bm25": {
        "enabled": true,
        "weight": 0.35
      },
      "vector_similarity": {
        "enabled": true,
        "weight": 0.65,
        "metric": "cosine"
      }
    },
    "embedding_models": [
      {
        "name": "text-embedding-3-large",
        "provider": "OpenAI",
        "dimensions": 3072,
        "priority": "primary"
      },
      {
        "name": "bge-large-en-v1.5",
        "provider": "local",
        "dimensions": 1024,
        "priority": "fallback"
      }
    ],
    "reranking": {
      "enabled": true,
      "model": "cross-encoder-ms-marco",
      "top_k": 20
    },
    "semantic_memory": {
      "enabled": true,
      "retention_days": 365,
      "compression": "adaptive"
    },
    "query_understanding": {
      "enabled": true,
      "intent_detection": true,
      "entity_resolution": true,
      "context_expansion": true
    }
  },

  "ontology": {
    "enabled": true,
    "model": "tamv-heptafederated-ontology-v3",
    "entity_types": [
      "repository",
      "module",
      "service",
      "federation",
      "pipeline",
      "knowledge-node",
      "semantic-cluster",
      "runtime",
      "dataset",
      "policy",
      "signal",
      "artifact"
    ],
    "relationship_types": [
      "depends_on",
      "extends",
      "implements",
      "publishes",
      "relates_to",
      "similar_to",
      "belongs_to",
      "derives_from",
      "references",
      "federates_with"
    ],
    "confidence_threshold": 0.67,
    "ontology_resolution_strategy": "multi-pass-semantic-resolution"
  },

  "classification": {
    "strategy": "hybrid-deterministic-semantic",
    "multi_label": true,
    "confidence_scoring": true,
    "labels": [
      "frontend",
      "backend",
      "semantic-runtime",
      "knowledge-graph",
      "cli",
      "ai-runtime",
      "observability",
      "federation",
      "security",
      "infrastructure",
      "atlas",
      "governance",
      "experimental",
      "production-ready",
      "research"
    ],
    "classification_layers": {
      "rules": {
        "enabled": true,
        "weight": 0.45
      },
      "semantic": {
        "enabled": true,
        "weight": 0.40
      },
      "graph_context": {
        "enabled": true,
        "weight": 0.15
      }
    }
  },

  "prediction_engine": {
    "enabled": true,
    "models": [
      "technical-debt-estimator",
      "production-readiness-model",
      "federation-stability-model",
      "architecture-drift-detector",
      "maintainability-score-model"
    ],
    "outputs": {
      "risk_score": true,
      "evolution_probability": true,
      "deployment_confidence": true,
      "maintenance_complexity": true,
      "semantic_decay": true
    },
    "forecast_horizon_days": 365,
    "drift_detection": {
      "enabled": true,
      "threshold": 0.28
    }
  },

  "knowledge_graph": {
    "enabled": true,
    "database": {
      "primary": "neo4j",
      "fallback": "json-graph"
    },
    "edge_weighting": {
      "semantic_similarity": 0.40,
      "shared_dependencies": 0.20,
      "shared_taxonomy": 0.20,
      "federation_affinity": 0.10,
      "historical_interaction": 0.10
    },
    "graph_features": {
      "causal_edges": true,
      "provenance_tracking": true,
      "federated_clustering": true,
      "lineage_tracking": true,
      "semantic_bridges": true
    }
  },

  "storage": {
    "primary": {
      "type": "postgresql",
      "extensions": [
        "pgvector",
        "timescaledb"
      ]
    },
    "vector_store": {
      "type": "qdrant",
      "replication": true
    },
    "graph_store": {
      "type": "neo4j"
    },
    "artifact_store": {
      "type": "s3-compatible"
    },
    "cache": {
      "type": "redis",
      "strategy": "semantic-lru"
    }
  },

  "security": {
    "mode": "zero-trust",
    "identity": {
      "workload_identity": true,
      "origin_attestation": true,
      "short_lived_credentials": true,
      "mfa_for_admin": true,
      "binding": "identity-first-per-request"
    },
    "sandbox": {
      "allow_code_execution": false,
      "allow_dynamic_imports": false,
      "allow_shell": false
    },
    "filesystem": {
      "symlink_protection": true,
      "path_traversal_protection": true,
      "allowlist_mode": true,
      "atomic_writes": true
    },
    "supply_chain": {
      "dependency_verification": true,
      "minimum_release_age_hours": 24,
      "integrity_checks": true
    },
    "secret_redaction": {
      "enabled": true,
      "patterns": [
        "aws",
        "jwt",
        "pem",
        "github_pat",
        "oauth",
        "private_key",
        "token",
        "apikey"
      ]
    },
    "audit": {
      "enabled": true,
      "immutable_logs": true,
      "event_signatures": true
    }
  },

  "observability": {
    "enabled": true,
    "metrics": {
      "prometheus": true,
      "custom_runtime_metrics": true
    },
    "tracing": {
      "enabled": true,
      "provider": "opentelemetry"
    },
    "logging": {
      "structured": true,
      "retention_days": 90
    },
    "runtime_signals": [
      "pipeline_latency",
      "semantic_accuracy",
      "classification_confidence",
      "graph_density",
      "ingestion_failures",
      "prediction_accuracy",
      "memory_pressure"
    ]
  },

  "deployment": {
    "strategy": "federated-hybrid-runtime",
    "targets": [
      "docker",
      "kubernetes",
      "bare-metal",
      "cloudflare-workers",
      "vercel",
      "linux-vps"
    ],
    "recommended_stack": {
      "frontend": "vite-tanstack-start",
      "backend": "node-tsx",
      "database": "postgresql-pgvector",
      "graph": "neo4j",
      "vectors": "qdrant",
      "cache": "redis",
      "queue": "bullmq"
    },
    "orchestration": {
      "workers": true,
      "queues": true,
      "incremental_jobs": true,
      "parallel_ingestion": true
    }
  },

  "patches": {
    "root_package_json": {
      "remove_invalid_scripts": [
        "tamv/cli/tamv.mjs",
        "scripts/health-check.mjs",
        "scripts/diagnostics.mjs",
        "scripts/observability.mjs"
      ],
      "replace_with": {
        "atlas:discover": "npm --workspace tamv-core-atlas run discover",
        "atlas:build": "npm --workspace tamv-core-atlas run build",
        "atlas:validate": "npm --workspace tamv-core-atlas run validate"
      }
    },
    "workspace": {
      "enabled": true,
      "manager": "pnpm",
      "file": "pnpm-workspace.yaml"
    },
    "ui_patch": {
      "nexus_graph": {
        "issue": "fixed-width-rendering",
        "solution": "resize-observer-responsive-runtime"
      }
    },
    "atlas_connection": {
      "strategy": "ui-consumes-generated-atlas-json",
      "files": [
        "atlas/index.json",
        "atlas/graph.json",
        "atlas/repos/*"
      ]
    }
  },

  "analysis_methods": {
    "repository_analysis": [
      "dependency-analysis",
      "semantic-embedding-analysis",
      "architectural-pattern-detection",
      "stack-inference",
      "federation-affinity-analysis",
      "technical-debt-analysis",
      "entropy-analysis"
    ],
    "prediction_methods": [
      "time-series-risk-analysis",
      "semantic-drift-analysis",
      "graph-centrality-analysis",
      "maintainability-scoring",
      "deployment-readiness-forecasting"
    ],
    "categorization_methods": [
      "ontology-mapping",
      "multi-label-semantic-classification",
      "embedding-clustering",
      "graph-contextual-inference"
    ]
  },

  "runtime_modules": {
    "semantic_engine": {
      "status": "partial",
      "readiness": 0.63
    },
    "graph_engine": {
      "status": "stable",
      "readiness": 0.79
    },
    "prediction_engine": {
      "status": "experimental",
      "readiness": 0.41
    },
    "ontology_engine": {
      "status": "beta",
      "readiness": 0.58
    },
    "atlas_pipeline": {
      "status": "stable-beta",
      "readiness": 0.82
    }
  },

  "professional_assessment": {
    "technical_positioning": "Strong conceptual architecture with hardened gateway, identity-first security and embedded epistemic governance.",
    "academic_positioning": "Research-grade federated semantic infrastructure prototype aligned with knowledge graph engineering, sovereign AI and zero-trust architectures.",
    "market_positioning": "Sovereign semantic intelligence platform for ecosystem mapping, operational cognition and verifiable governance.",
    "critical_weaknesses": [
      "Some kernel modules still conceptual or partial",
      "UI remains dependent on seed data and generated artifacts",
      "Missing fully automated production CI/CD",
      "Prediction engine not yet fully validated on real-world datasets"
    ],
    "major_strengths": [
      "Strong secure ingestion architecture",
      "Identity-first zero-trust hardening",
      "Heptafederated conceptual model with cognitive governance",
      "Defensive filesystem and supply-chain design",
      "Scalable semantic and graph cognition potential",
      "Ecosystem and claim auditability via IsabellaEngine"
    ],
    "realistic_next_steps": [
      "Convert atlas pipeline into official workspace package",
      "Connect UI to generated atlas artifacts",
      "Implement semantic embedding persistence",
      "Deploy and tune graph database",
      "Add queue-based ingestion and backpressure control",
      "Implement telemetry dashboards and SLOs",
      "Formalize ontology and policy schemas",
      "Run end-to-end audits of real ecosystems using auditoria-ecosistema profile"
    ]
  }
}
