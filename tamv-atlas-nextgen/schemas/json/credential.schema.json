{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tamv.online/schemas/credential.schema.json",
  "title": "Credential",
  "type": "object",
  "required": ["id", "path", "provider", "authMethod", "addedAt", "securityLevel"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "path": {"type": "string"},
    "provider": {"type": "string"},
    "authMethod": {"enum": ["refresh-token", "bearer", "oauth2", "dilithium5", "zk-snark"]},
    "addedAt": {"type": "string", "format": "date-time"},
    "isniIdentity": {"type": "string"},
    "securityLevel": {"enum": ["standard", "post-quantum", "quantum-resistant"]},
    "bookpiAnchor": {"type": "string"}
  },
  "additionalProperties": false
}
