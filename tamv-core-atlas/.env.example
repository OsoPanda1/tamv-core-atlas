# GitHub personal access token with `public_repo` scope (read-only).
# Use a token with the MINIMUM required permissions.
GITHUB_TOKEN=

# Owner whose repos will be discovered (user or org).
GITHUB_OWNER=OsoPanda1

# Set to "true" to include forked repos.
INCLUDE_FORKS=false

# Hard cap on number of repos processed per run (safety valve).
MAX_REPOS=500

# Concurrency for network operations.
CONCURRENCY=6