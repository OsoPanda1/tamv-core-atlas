    "observability": {
      "enabled": true,
      "providers": ["pino", "opentelemetry", "horus-local"],
      "metrics": {
        "namespace": "tamv_core",
        "export": ["prometheus", "otlp"],
        "dashboards": ["grafana", "kibana"]
      },
      "tracing": {
        "enabled": true,
        "sampler": "parentbased_always_on",
        "serviceName": "tamv-atlas-core",
        "resourceAttributes": {
          "service.namespace": "tamv",
          "service.version": "0.1.0-rc.1",
          "tamv.kernel": "ATLAS_CORE_MD-X4"
        }
      },
      "logging": {
        "level": "info",
        "pretty": true,
        "redact": ["password", "token", "secret", "privateKey", "mnemonic"]
      }
    },

    "security": {
      "csp": "strict",
      "helmet": true,
      "rateLimit": {
        "enabled": true,
        "windowMs": 60000,
        "max": 120
      },
      "csrf": {
        "enabled": true,
        "sameSite": "lax"
      },
      "postQuantum": {
        "enabled": false,
        "notes": "pendiente capa de abstracción de criptografía PQC"
      }
    },

    "comments": {
      "core": "núcleo app / kernel",
      "quality": "calidad / análisis estático",
      "cleanup": "limpieza multiplataforma",
      "observability": "HORUS + OpenTelemetry",
      "security": "ANUBIS + CSRF + rate limiting + MSR ledger"
