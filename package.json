        "L5_SOVEREIGN_IDENTITY": {
          "code": "L5",
          "name": "ID-NVIDA™",
          "role": "Identidad soberana, DID, ZKP, biometría cancelable",
          "modules": [
            "src/kernel/l5/id-nvida-core.ts",
