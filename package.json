        "L6_USER_INTERACTION": {
          "code": "L6",
          "name": "Isabella Villaseñor AI™",
          "role": "Cognición neuro-simbólica y UX de conciencia colectiva",
          "modules": [
            "src/kernel/l6/isabella-core.ts",
            "src/kernel/l6/context-orchestrator.ts",
            "src/kernel/l6/eoct-gateway.ts"
