    "tamv:sync-ledger": "node tamv/cli/tamv.mjs sync-ledger",
    "tamv:agents": "node tamv/cli/tamv.mjs agents",
    "tamv:eoct-check": "node tamv/cli/tamv.mjs eoct-check",

    "ci:fast": "npm run lint && npm run typecheck && npm run test",
    "ci:full": "npm run lint && npm run typecheck && npm run test:coverage && npm run test:e2e && npm run build"
