      "heptafederation": {
        "L0_ONTOLOGICAL_FILTER": {
          "code": "L0",
          "name": "DEKATEOTL™ Interceptor",
          "role": "Hard Dignity Stop / filtro ético ontológico",
          "modules": [
            "src/kernel/l0/dekateotl-core.ts",
            "src/kernel/l0/eoct-filter.ts",
            "src/kernel/l0/kormia-guard.ts"
          ],
          "constraints": ["non-negotiable", "pre-execution"]
        },
        "L1_EPISODICAL_MEMORY": {
          "code": "L1",
          "name": "TAMV Memory Engine",
          "role": "Memoria episódica soberana / SDMD-7",
          "modules": [
            "src/kernel/l1/sdmd-7.ts",
            "src/kernel/l1/time-space-shells.ts",
            "src/kernel/l1/memory-grid.ts"
          ],
          "backends": ["local", "crdt", "ledger-linked"]
        },
        "L2_CRYPTO_IMMUTABILITY": {
          "code": "L2",
          "name": "BookPI™ + MSR Blockchain",
          "role": "Inmutabilidad criptográfica / ledger histórico",
