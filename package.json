            "src/kernel/l2/datagit-sync.ts"
          ],
          "features": ["canon-proof", "snapshots", "forensic-audit"]
        },
        "L3_PERIMETER_SECURITY": {
          "code": "L3",
          "name": "ANUBIS Sentinel™ + HORUS Watch",
          "role": "Ciberdefensa, monitoreo y correlación de amenazas",
