      "bootstrap": {
        "entryServer": "src/server/bootstrap.ts",
        "entryClient": "src/client/bootstrap.tsx",
        "cli": "tamv/cli/tamv.mjs",
        "envProfileVar": "TAMV_ENV",
        "supportedProfiles": ["development", "staging", "production", "island"]
