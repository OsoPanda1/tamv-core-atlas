        "L4_SENSORIAL_LAYER": {
          "code": "L4",
          "name": "KAOS Audio™ + HyperRender X4",
          "role": "Capa sensorial XR (audio espacial, WebXR, 4D)",
          "modules": [
            "src/kernel/l4/kaos-audio.ts",
            "src/kernel/l4/hyperrender-x4.ts",
            "src/kernel/l4/visual-bridges.ts"
          ],
          "targets": ["webxr", "4d-spaces", "multisensory-shells"]
