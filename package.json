      "horus": {
        "id": "HORUS-WATCH",
        "type": "observability-sentinel",
        "modes": ["metrics", "traces", "alerts"],
        "entry": "src/agents/horus/bootstrap.ts",
        "bindings": ["observability"]
      },
      "eoct": {
        "id": "EOCT-ENGINE",
        "type": "semantic-recomposition",
        "role": "Recomposición semántica determinista + filtro ético",
        "entry": "src/agents/eoct/bootstrap.ts",
        "bindings": ["L0_ONTOLOGICAL_FILTER", "L6_USER_INTERACTION"]
      }
