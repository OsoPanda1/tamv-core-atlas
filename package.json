      "rootName": "ROOT CANON — tanstack_start_ts",
      "acos": true,
      "doi": "10.5281/zenodo.19436662",
      "orcid": "0009-0008-5050-1539",
      "lineage": {
        "architect": "Edwin Oswaldo Castillo Trejo (Anubis Villaseñor)",
