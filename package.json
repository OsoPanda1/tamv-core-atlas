            "src/kernel/l7/elite-hehep.ts",
            "src/kernel/l7/gemet-governor.ts",
            "src/kernel/l7/dekateotl-governance.ts"
          ],
          "pipelines": ["thcf", "governance-ci", "canon-migrations"]
        }
      },
      "mesh": {
        "citemesh": {
          "id": "CITEMESH-PRIMUS",
          "role": "Reality Operating System / malla civilizatoria",
          "docsRef": "docs/citemesh-whitepaper-v1.md",
